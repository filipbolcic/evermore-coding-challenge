generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id       String   @id @default(uuid())
  title    String
  startUtc DateTime @map("start_time") @db.Timestamptz(0)
  endUtc   DateTime @map("end_time") @db.Timestamptz(0)

  @@map("events")
}
